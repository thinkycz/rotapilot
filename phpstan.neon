includes:
    - ./vendor/phpstan/phpstan/conf/bleedingEdge.neon
    - ./vendor/spaze/phpstan-disallowed-calls/disallowed-dangerous-calls.neon
    - ./vendor/spaze/phpstan-disallowed-calls/disallowed-execution-calls.neon
    - ./vendor/spaze/phpstan-disallowed-calls/disallowed-insecure-calls.neon
    - ./vendor/spaze/phpstan-disallowed-calls/disallowed-loose-calls.neon
#    - ./phpstan-baseline.neon

parameters:
  level: max
  treatPhpDocTypesAsCertain: false
  checkMissingCallableSignature: true
  checkTooWideReturnTypesInProtectedAndPublicMethods: true
  checkUninitializedProperties: true
  reportAlwaysTrueInLastCondition: true
  checkBenevolentUnionTypes: true
  strictRules:
    # Larastan models Eloquent's magic fluent builder calls through method
    # reflections that PHPStan strict-rules sees as static. Keep the rest of
    # strict-rules active, but do not report normal `$query->where()` /
    # `$query->forUser()` builder chains as dynamic static calls.
    dynamicCallOnStaticMethod: false
  paths:
    - ./app
    - ./config
    - ./database
    - ./packages
    - ./routes
  excludePaths:
    - ./tests
