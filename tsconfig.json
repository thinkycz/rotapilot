{
    "extends": "@vue/tsconfig/tsconfig.dom.json",
    "compilerOptions": {
        "allowJs": true,
        "baseUrl": ".",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "paths": {
            "@/*": ["resources/js/*"]
        },
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "types": ["vite/client", "node"]
    },
    "include": ["resources/js/**/*.ts", "resources/js/**/*.vue"]
}
